// lib/features/auth/data/change_password_api.dart
import 'dart:convert';
import 'package:tectrackerbpm/core/api/api_client.dart';

class ChangePasswordApi {
  final ApiClient _client = ApiClient();

  Future<void> changePassword({
    required String newPassword,
  }) async {
    final resp = await _client.post(
      '/api/auth/change-password',
      auth: true,
      body: {
        'Password': newPassword,
      },
    );

    if (resp.statusCode == 200 || resp.statusCode == 204) return;

    // intenta leer mensaje
    try {
      final data = jsonDecode(resp.body);
      final msg = (data is Map && data['message'] != null)
          ? data['message'].toString()
          : resp.body;
      throw Exception(msg.isEmpty ? 'Error cambiando contraseña' : msg);
    } catch (_) {
      throw Exception('Error cambiando contraseña: ${resp.statusCode} - ${resp.body}');
    }
  }
}
